{
  "name": "calendar-wallpaper",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "render": "node render.js",
    "render:force": "node render.js --force",
    "refresh-holidays": "node refresh-holiday-data.js",
    "refresh-holidays:if-needed": "node refresh-holiday-data.js --if-needed --days 90 --min-days 14 --strict-providers",
    "content:gaps": "node list-holiday-content-gaps.js",
    "content:gaps:check": "node list-holiday-content-gaps.js --fail-on-gaps --require-provider-data",
    "content:scan": "node scan-holiday-content-coverage.js",
    "content:audit": "node audit-holiday-content-coverage.js",
    "content:validate": "node validate-holiday-content.js",
    "publish:restore-history": "node publish-generated-assets.js restore-history",
    "publish:archive": "node publish-generated-assets.js publish-archive",
    "diagnostics": "node collect-action-diagnostics.js"
  },
  "dependencies": {
    "puppeteer": "25.1.0"
  }
}
